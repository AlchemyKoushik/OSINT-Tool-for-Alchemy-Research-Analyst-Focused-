OPENAI_API_KEY=replace-me
OPENAI_ANALYSIS_MODEL=gpt-4.1
OPENAI_SUPPORT_MODEL=gpt-4.1-mini
OPENAI_QUERY_MODEL=gpt-4.1-mini
OPENAI_TEST_MODEL=gpt-4.1-mini
SCRAPEDO_KEY=replace-me
SERPAPI_KEY=
USE_CRAWL4AI=false
COMPARE_CRAWLERS=false
REDIS_URL=redis://redis:6379/0
CLOUDFLARE_R2_ACCOUNT_ID=replace-me
CLOUDFLARE_R2_ACCESS_KEY_ID=replace-me
CLOUDFLARE_R2_SECRET_ACCESS_KEY=replace-me
CLOUDFLARE_R2_BUCKET_NAME=replace-me
CLOUDFLARE_R2_REGION=auto
EXTERNAL_TIMEOUT_SECONDS=20
EXTERNAL_MAX_RETRIES=3
SCRAPER_MAX_CONCURRENT_REQUESTS=4
CRAWL4AI_TIMEOUT_SECONDS=15
CACHE_TTL_SECONDS=3600
SESSION_TTL_SECONDS=3600
RATE_LIMIT_REQUESTS_PER_MINUTE=10
JOB_TTL_SECONDS=21600
JOB_POLL_TIMEOUT_SECONDS=5
JOB_MAX_RETRIES=3
WORKER_IDLE_SLEEP_SECONDS=1.0
